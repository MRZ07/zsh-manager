# Secrets template — copy this file to secrets.sh and fill in your values.
#   cp secrets.sh.example secrets.sh
#
# This file is tracked in git. Any *.sh file alongside it is gitignored.
#
# Split secrets into multiple files as needed, e.g.:
#   api-keys.sh   — third-party API keys
#   work.sh       — work-specific tokens
#   personal.sh   — personal credentials
#
# OS-specific secrets go in secrets/macos/, secrets/linux/, secrets/windows/

# export SOME_API_KEY=""
# export SOME_TOKEN=""
